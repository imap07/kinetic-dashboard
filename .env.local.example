# Copy to `.env.local` and fill in the real values. `.env.local` is
# gitignored — never commit a real AUTH_SECRET.

# Backend API (NestJS) — local NestJS for dev, Lightsail for prod
BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
# Production:
# BACKEND_URL=https://kinectic-app-test.4a7ymmxg576we.ca-central-1.cs.amazonlightsail.com
# NEXT_PUBLIC_BACKEND_URL=https://kinectic-app-test.4a7ymmxg576we.ca-central-1.cs.amazonlightsail.com

# NextAuth — generate with: openssl rand -base64 32
# MUST be different per environment (dev vs prod). Rotate after any leak.
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
